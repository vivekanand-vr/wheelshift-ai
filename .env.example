# Environment
ENV=development

# Database Configuration
# For local development (outside Docker): use localhost:3307
# For Docker: use mysql:3306 (automatically set in docker-compose.yml)
DB_HOST=localhost
DB_PORT=3307
DB_USER=wheelshift_ai
DB_PASSWORD=your_secure_password_here
DB_NAME=wheelshift_db

# Redis Configuration
# For local development (outside Docker): use localhost:6379
# For Docker: use redis:6379 (automatically set in docker-compose.yml)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1
REDIS_PASSWORD=

# Feature Flags
ENABLE_COLLABORATIVE_FILTERING=true
MIN_INTERACTIONS_THRESHOLD=50
MIN_CLIENTS_THRESHOLD=10

# Caching Configuration
CACHE_TTL_ONDEMAND=1800  # 30 minutes in seconds
CACHE_TTL_PRECOMPUTED=86400  # 24 hours in seconds
FEATURE_VECTOR_CACHE_TTL=3600  # 1 hour in seconds

# Similarity Configuration
DEFAULT_SIMILARITY_LIMIT=10
PRICE_BAND_PERCENTAGE=0.15  # ±15%
TOP_VEHICLES_PRECOMPUTE=100

# Feature Weights
WEIGHT_PRICE=0.25
WEIGHT_BRAND=0.20
WEIGHT_BODY_TYPE=0.15
WEIGHT_YEAR=0.15
WEIGHT_MILEAGE=0.10
WEIGHT_FUEL_TYPE=0.10
WEIGHT_TEXT_SIMILARITY=0.05

# Hybrid Model Weights
CONTENT_BASED_WEIGHT=0.6
COLLABORATIVE_WEIGHT=0.4

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_TRACK_STARTED=true
CELERY_TASK_TIME_LIMIT=1800  # 30 minutes
